   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Loaded BEST checkpoint: ./mm_finetuned.pth | best val acc: 0.9116666666666666\n",
      "Classes: ['Black', 'Blue', 'Green', 'TTR']\n"
     ]
    }
   ],
   "source": [
    "# SALIENCY MAP\n",
    "\n",
    "import os\n",
    "import re\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from PIL import Image\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "\n",
    "# Helper: clean filename text\n",
    "def filename_to_text(path: str) -> str:\n",
    "    name = os.path.splitext(os.path.basename(path))[0]\n",
    "    name = re.sub(r\"[_\\-]+\", \" \", name)\n",
    "    name = re.sub(r\"_\\d+$\", \"\", name)\n",
    "    name = re.sub(r\"\\s+\", \" \", name).strip()\n",
    "    return name\n",
    "\n",
    "# Helper: reverse normalization for display\n",
    "def unnormalize_image(img_tensor):\n",
    "    mean = torch.tensor([0.485, 0.456, 0.406], device=img_tensor.device).view(3, 1, 1)\n",
    "    std  = torch.tensor([0.229, 0.224, 0.225], device=img_tensor.device).view(3, 1, 1)\n",
    "    img = img_tensor * std + mean\n",
    "    return img.clamp(0, 1)\n",
    "\n",
    "# Helper: choose best checkpoint\n",
    "def pick_best_ckpt(head_ckpt, ft_ckpt):\n",
    "    best_path = None\n",
    "    best_acc = -1.0\n",
    "\n",
    "    if os.path.exists(head_ckpt):\n",
    "        c = torch.load(head_ckpt, map_location=\"cpu\")\n",
    "        acc = float(c.get(\"best_acc\", c.get(\"best_val_acc\", -1.0)))\n",
    "        if acc > best_acc:\n",
    "            best_acc = acc\n",
    "            best_path = head_ckpt\n",
    "\n",
    "    if os.path.exists(ft_ckpt):\n",
    "        c = torch.load(ft_ckpt, map_location=\"cpu\")\n",
    "        acc = float(c.get(\"best_acc\", c.get(\"best_val_acc\", -1.0)))\n",
    "        if acc > best_acc:\n",
    "            best_acc = acc\n",
    "            best_path = ft_ckpt\n",
    "\n",
    "    if best_path is None:\n",
    "        raise FileNotFoundError(\"No checkpoint found.\")\n",
    "\n",
    "    return best_path, best_acc\n",
    "\n",
    "# Load best trained weights into our existing model\n",
    "PATH, best_acc = pick_best_ckpt(HEAD_CKPT, FT_CKPT)\n",
    "ckpt = torch.load(PATH, map_location=device)\n",
    "model.load_state_dict(ckpt[\"model\"])\n",
    "model.to(device)\n",
    "model.eval()\n",
    "\n",
    "print(\"Loaded BEST checkpoint:\", PATH, \"| best val acc:\", best_acc)\n",
    "\n",
    "# Class names from our dataset\n",
    "class_names = image_datasets[\"train\"].classes\n",
    "print(\"Classes:\", class_names)\n",
    "\n",
    "# Image preprocessing for saliency\n",
    "saliency_preprocess = transform[\"eval\"]\n",
    "\n",
    "# Function: build saliency map\n",
    "# image_path     -> path to one test image\n",
    "# target_class   -> optional class name string\n",
    "#                   if None, uses model prediction\n",
    "# output_dir     -> where to save outputs\n",
    "def generate_saliency_map(image_path, target_class=None, output_dir=\"saliency_outputs\"):\n",
    "    os.makedirs(output_dir, exist_ok=True)\n",
    "\n",
    "    # ----- Load image -----\n",
    "    img_pil = Image.open(image_path).convert(\"RGB\")\n",
    "\n",
    "    # ----- Build text input from filename -----\n",
    "    text_input = filename_to_text(image_path)\n",
    "\n",
    "    enc = tokenizer(\n",
    "        [text_input],\n",
    "        padding=True,\n",
    "        truncation=True,\n",
    "        max_length=32,\n",
    "        return_tensors=\"pt\"\n",
    "    )\n",
    "    enc = {k: v.to(device) for k, v in enc.items()}\n",
    "    \n",
    "# ----- Preprocess image -----\n",
    "    img_tensor = saliency_preprocess(img_pil).unsqueeze(0).to(device)\n",
    "    img_tensor.requires_grad_(True)\n",
    "\n",
    "    # ----- Forward pass -----\n",
    "    model.zero_grad()\n",
    "    logits = model(img_tensor, enc)\n",
    "    probs = F.softmax(logits, dim=1)\n",
    "\n",
    "    pred_idx = int(torch.argmax(logits, dim=1).item())\n",
    "    pred_class = class_names[pred_idx]\n",
    "    pred_prob = float(probs[0, pred_idx].item())\n",
    "\n",
    "    # ----- Decide which class to visualize -----\n",
    "    if target_class is None:\n",
    "        target_idx = pred_idx\n",
    "        target_name = pred_class\n",
    "    else:\n",
    "        if target_class not in class_names:\n",
    "            raise ValueError(f\"Class '{target_class}' not found. Available classes: {class_names}\")\n",
    "        target_idx = class_names.index(target_class)\n",
    "        target_name = target_class\n",
    "\n",
    "    # ----- Backprop for selected class -----\n",
    "    score = logits[0, target_idx]\n",
    "    score.backward()\n",
    "\n",
    "    # ----- Compute saliency -----\n",
    "    grad = img_tensor.grad.detach().cpu().numpy()[0]         # (3, H, W)\n",
    "    saliency = np.abs(grad).max(axis=0)                      # (H, W)\n",
    "\n",
    "    # Normalize to [0, 1] for display\n",
    "    saliency = saliency - saliency.min()\n",
    "    saliency = saliency / (saliency.max() + 1e-12)\n",
    "\n",
    "    # ----- Prepare display image -----\n",
    "    img_vis = unnormalize_image(img_tensor[0].detach()).cpu().permute(1, 2, 0).numpy()\n",
    "\n",
    "    # ----- Save base filenames -----\n",
    "    base = os.path.splitext(os.path.basename(image_path))[0]\n",
    "\n",
    "    original_save = os.path.join(output_dir, f\"{base}_original.png\")\n",
    "    cropped_save  = os.path.join(output_dir, f\"{base}_preprocessed.png\")\n",
    "    heatmap_save  = os.path.join(output_dir, f\"{base}_saliency_{target_name}.png\")\n",
    "    overlay_save  = os.path.join(output_dir, f\"{base}_overlay_{target_name}.png\")\n",
    "\n",
    "    # Save original image\n",
    "    img_pil.save(original_save)\n",
    "\n",
    "    # Save preprocessed/visible image\n",
    "    plt.figure(figsize=(5, 5))\n",
    "    plt.imshow(img_vis)\n",
    "    plt.axis(\"off\")\n",
    "    plt.title(\"Preprocessed Image\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(cropped_save, bbox_inches=\"tight\", pad_inches=0.1)\n",
    "    plt.show()\n",
    "\n",
    "    # Save saliency heatmap\n",
    "    plt.figure(figsize=(5, 5))\n",
    "    plt.imshow(saliency, cmap=\"hot\")\n",
    "    plt.axis(\"off\")\n",
    "    plt.title(f\"Saliency Map\\nTarget: {target_name}\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(heatmap_save, bbox_inches=\"tight\", pad_inches=0.1)\n",
    "    plt.show()\n",
    "\n",
    "    # Save overlay\n",
    "    plt.figure(figsize=(5, 5))\n",
    "    plt.imshow(img_vis)\n",
    "    plt.imshow(saliency, cmap=\"hot\", alpha=0.45)\n",
    "    plt.axis(\"off\")\n",
    "    plt.title(f\"Overlay\\nTarget: {target_name}\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(overlay_save, bbox_inches=\"tight\", pad_inches=0.1)\n",
    "    plt.show()\n",
    "\n",
    "    # ----- Print summary -----\n",
    "    print(\"--------------------------------------------------\")\n",
    "    print(\"Image path:        \", image_path)\n",
    "    print(\"Filename text used:\", text_input)\n",
    "    print(\"Predicted class:   \", pred_class)\n",
    "    print(\"Predicted prob:    \", f\"{pred_prob:.4f}\")\n",
    "    print(\"Saliency target:   \", target_name)\n",
    "    print(\"Saved files:\")\n",
    "    print(\"  \", original_save)\n",
    "    print(\"  \", cropped_save)\n",
    "    print(\"  \", heatmap_save)\n",
    "    print(\"  \", overlay_save)\n",
    "    print(\"--------------------------------------------------\")\n",
    "\n",
    "    return {\n",
    "        \"predicted_class\": pred_class,\n",
    "        \"predicted_prob\": pred_prob,\n",
    "        \"target_class\": target_name,\n",
    "        \"saliency_map\": saliency,\n",
    "        \"display_image\": img_vis,\n",
    "        \"paths\": {\n",
    "            \"original\": original_save,\n",
    "            \"preprocessed\": cropped_save,\n",
    "            \"heatmap\": heatmap_save,\n",
    "            \"overlay\": overlay_save\n",
    "        }\n",
    "    }"
   ]
  },
